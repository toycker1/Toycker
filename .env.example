# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Cloudflare R2 Configuration (for product images)
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_KEY=your-secret-key
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=your-bucket-name
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-public-cdn-domain.com

# PayU Payment Gateway (legacy — kept for revert safety)
PAYU_MERCHANT_KEY=your-merchant-key
PAYU_MERCHANT_SALT=your-merchant-salt
PAYU_ENVIRONMENT=test # or production

# Easebuzz Payment Gateway (active)
EASEBUZZ_MERCHANT_KEY=your-merchant-key
EASEBUZZ_MERCHANT_SALT=your-merchant-salt
EASEBUZZ_ENVIRONMENT=test # or prod

# App Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_COUNTRY_CODE=IN

# Analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_CONTENTSQUARE_ID=your-contentsquare-id
NEXT_PUBLIC_META_PIXEL_ID=1045186905334220

BREVO_API_KEY=your_brevo_api_key_here
CONTACT_FORM_RECIPIENT=your_recipient_email_here
CONTACT_FORM_SENDER=your_verified_sender_email_here

# AiSensy WhatsApp OTP
AISENSY_API_KEY=your-aisensy-api-key
AISENSY_CAMPAIGN_NAME=Toycker Whatsapp Login OTP Verification 4 Digit
AISENSY_BASE_URL=https://backend.aisensy.com/campaign/t1/api/v2
AISENSY_SOURCE=new-landing-page form
AISENSY_AUTH_TEMPLATE_EXTRA_PAYLOAD_JSON={"media":{},"buttons":[{"type":"button","sub_type":"url","index":0,"parameters":[{"type":"text","text":"{{OTP_CODE}}"}]}],"carouselCards":[],"location":{},"attributes":{},"paramsFallbackValue":{"FirstName":"user"}}

# Interakt WhatsApp OTP
# API key: Interakt Dashboard > Developer Settings
INTERAKT_API_KEY=your-interakt-api-key
# Template code name: created in Meta Business Manager, synced in Interakt > Templates
INTERAKT_TEMPLATE_NAME=your_template_code_name
# Language code used when creating the template (default: en)
INTERAKT_LANGUAGE_CODE=en

OTP_HASH_SECRET=replace-with-a-long-random-secret
OTP_TTL_SECONDS=180
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=3
WHATSAPP_LOGIN_EMAIL_DOMAIN=wa.toycker.store
